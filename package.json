{
    "name": "@priscilo/calculadora-cientifica",
    "version": "1.0.0",
    "description": "Calculadora científica con React, Vite y Electron",
    "main": "main.js",
    "scripts": {
        "dev": "vite",
        "electron": "electron .",
        "start": "concurrently \"vite\" \"electron .\"",
        "build:web": "vite build",
        "build:electron": "electron-builder",
        "lint": "eslint . --ext .js,.jsx",
        "format": "prettier --write ."
    },
    "dependencies": {
        "react": "^18.2.0",
        "react-dom": "^18.2.0",
        "mathjs": "^12.4.0"
    },
    "devDependencies": {
        "electron": "^29.0.0",
        "vite": "^7.3.1",
        "@vitejs/plugin-react": "^4.2.0",
        "concurrently": "^8.2.2",
        "eslint": "^9.0.0",
        "prettier": "^3.2.5",
        "electron-builder": "^24.13.3"
    },
    "repository": {
        "type": "git",
        "url": "https://github.com/priscilo/Calculadora-Cient-fica.git"
    },
    "bugs": {
        "url": "https://github.com/priscilo/Calculadora-Cient-fica/issues"
    },
    "homepage": "https://github.com/priscilo/Calculadora-Cient-fica#readme",
    "engines": {
        "node": ">=18"
    },
    "publishConfig": {
        "registry": "https://npm.pkg.github.com/"
    }
}